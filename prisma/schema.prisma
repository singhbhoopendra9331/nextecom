// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  name                String?
  password            String
  role                UserRole             @default(EDITOR)
  sessionVersion      Int                  @default(0)
  posts               Post[]
  passwordResetTokens PasswordResetToken[]
  createdAt           DateTime             @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model Media {
  id String @id @default(uuid())

  // File info
  filename     String
  originalName String
  mimeType     String
  size         Int

  // Storage info
  url        String
  provider   MediaProvider
  providerId String? // e.g. Cloudinary public_id

  // Image metadata (optional)
  width  Int?
  height Int?

  // SEO / CMS fields
  alt     String?
  caption String?

  // Optional UX improvements
  blurhash      String?
  dominantColor String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  featuredInPosts Post[]
  featuredInPages Page[]
}

enum MediaProvider {
  LOCAL
  CLOUDINARY
  S3
}

model Post {
  id      String @id @default(uuid())
  title   String
  slug    String @unique
  content Json // Richtext, supports Blocknote format

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  tags       Tag[]      @relation("PostTags")
  categories Category[] @relation("PostCategories")

  featuredImage   Media?  @relation(fields: [featuredImageId], references: [id])
  featuredImageId String?

  status PostStatus @default(DRAFT)

  meta      Meta[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id    String @id @default(uuid())
  name  String @unique
  posts Post[] @relation("PostTags")
}

model Category {
  id    String @id @default(uuid())
  name  String @unique
  posts Post[] @relation("PostCategories")
}

model Meta {
  id    String @id @default(uuid())
  key   String
  value String

  post   Post?  @relation(fields: [postId], references: [id])
  postId String?

  page   Page?  @relation(fields: [pageId], references: [id])
  pageId String?
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Page {
  id      String @id @default(uuid())
  title   String
  slug    String @unique
  content Json   @default("[]")

  status PostStatus @default(DRAFT)

  featuredImage   Media?  @relation(fields: [featuredImageId], references: [id])
  featuredImageId String?

  meta      Meta[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// WordPress-style key/value store for site and plugin settings.
model Option {
  id     String  @id @default(uuid())
  key    String  @unique
  value  Json
  /// When true, load with other autoload options (like WP autoload = yes).
  autoload Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("options")
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

model ApplicationLog {
  id        String   @id @default(uuid())
  level     LogLevel
  message   String   @db.Text
  context   Json?
  stack     String?  @db.Text
  source    String?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
  @@index([source])
  @@map("application_logs")
}