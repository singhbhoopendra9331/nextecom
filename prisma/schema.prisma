// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  name                String?
  password            String
  role                UserRole             @default(EDITOR)
  sessionVersion      Int                  @default(0)
  posts               Post[]
  passwordResetTokens PasswordResetToken[]
  createdAt           DateTime             @default(now())
  comments            Comment[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model Media {
  id String @id @default(uuid())

  // File info
  filename     String
  originalName String
  mimeType     String
  size         Int

  // Storage info
  url        String
  provider   MediaProvider
  providerId String? // e.g. Cloudinary public_id

  // Image metadata (optional)
  width  Int?
  height Int?

  // SEO / CMS fields
  alt     String?
  caption String?

  // Optional UX improvements
  blurhash      String?
  dominantColor String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  featuredInPosts    Post[]
  featuredInPages    Page[]
  featuredInProducts Product[]
  productImages      ProductImage[]
}

enum MediaProvider {
  LOCAL
  CLOUDINARY
  S3
}

model Post {
  id      String @id @default(uuid())
  title   String
  slug    String @unique
  content Json // Richtext, supports Blocknote format

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  tags       Tag[]      @relation("PostTags")
  categories Category[] @relation("PostCategories")

  featuredImage   Media?  @relation(fields: [featuredImageId], references: [id])
  featuredImageId String?

  status PostStatus @default(DRAFT)

  meta      Meta[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]
}

model Tag {
  id       String    @id @default(uuid())
  name     String    @unique
  posts    Post[]    @relation("PostTags")
  products Product[] @relation("ProductTags")
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  posts    Post[]    @relation("PostCategories")
  products Product[] @relation("ProductCategories")
}

model Meta {
  id    String @id @default(uuid())
  key   String
  value String

  post   Post?   @relation(fields: [postId], references: [id])
  postId String?

  page   Page?   @relation(fields: [pageId], references: [id])
  pageId String?

  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String?

  @@index([productId])
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Page {
  id      String @id @default(uuid())
  title   String
  slug    String @unique
  content Json   @default("[]")

  status PostStatus @default(DRAFT)

  featuredImage   Media?  @relation(fields: [featuredImageId], references: [id])
  featuredImageId String?

  meta Meta[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// WordPress-style key/value store for site and plugin settings.
model Option {
  id       String  @id @default(uuid())
  key      String  @unique
  value    Json
  /// When true, load with other autoload options (like WP autoload = yes).
  autoload Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("options")
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

model ApplicationLog {
  id        String   @id @default(uuid())
  level     LogLevel
  message   String   @db.Text
  context   Json?
  stack     String?  @db.Text
  source    String?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
  @@index([source])
  @@map("application_logs")
}

enum FormStatus {
  ACTIVE
  INACTIVE
}

model Form {
  id          String           @id @default(uuid())
  title       String
  slug        String           @unique
  status      FormStatus       @default(ACTIVE)
  fields      Json
  email       Json?
  submit      Json
  submissions FormSubmission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("forms")
}

model FormSubmission {
  id        String   @id @default(uuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  data      Json
  ip        String?
  source    String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([formId])
  @@index([createdAt])
  @@map("form_submissions")
}

model Comment {
  id String @id @default(uuid())

  // Content
  content String        @db.Text
  status  CommentStatus @default(PENDING)

  // Guest information
  authorName  String
  authorEmail String
  authorUrl   String?

  // Metadata
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId String?

  parent   Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?

  replies Comment[] @relation("CommentReplies")

  @@index([postId])
  @@index([status])
  @@index([parentId])
  @@index([createdAt])
}

enum CommentStatus {
  PENDING
  APPROVED
  SPAM
  TRASH
}

enum ProductType {
  SIMPLE
  VARIABLE
  AFFILIATE
}

enum ProductStatus {
  DRAFT
  PENDING
  PRIVATE
  PUBLISHED
}

enum CatalogVisibility {
  SHOP
  SEARCH
  HIDDEN
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  ON_BACKORDER
}

enum BackorderMode {
  NO
  NOTIFY
  YES
}


model Brand {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String    @unique
  products Product[]

  @@map("brands")
}

model Product {
  id String @id @default(uuid())

  // Content
  title            String
  slug             String      @unique
  description      Json        @default("[]")
  shortDescription String?     @db.Text
  type             ProductType @default(SIMPLE)

  // Status & visibility
  status             ProductStatus     @default(DRAFT)
  catalogVisibility  CatalogVisibility @default(SHOP)
  isFeatured         Boolean           @default(false)
  menuOrder          Int               @default(0)

  // Media
  featuredImage   Media?  @relation(fields: [featuredImageId], references: [id])
  featuredImageId String?
  gallery         ProductImage[]

  // Taxonomy
  categories Category[] @relation("ProductCategories")
  tags       Tag[] @relation("ProductTags")
  brand      Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  brandId    String?

  // Pricing (simple / affiliate products)
  regularPrice Decimal? @db.Decimal(12, 2)
  salePrice    Decimal? @db.Decimal(12, 2)
  costPrice    Decimal? @db.Decimal(12, 2)
  taxClass     String?
  currency     String   @default("USD")

  // Inventory (simple products)
  sku            String?       @unique
  manageStock    Boolean       @default(false)
  quantity       Int           @default(0)
  stockStatus    StockStatus   @default(IN_STOCK)
  allowBackorder BackorderMode @default(NO)

  // Shipping
  weight Decimal? @db.Decimal(10, 3)
  length Decimal? @db.Decimal(10, 2)
  width  Decimal? @db.Decimal(10, 2)
  height Decimal? @db.Decimal(10, 2)

  // Reviews
  enableReviews Boolean  @default(true)
  averageRating Decimal? @db.Decimal(3, 2)
  ratingCount   Int      @default(0)

  // SEO
  metaTitle       String?
  metaDescription String? @db.Text
  canonicalUrl    String?

  // Custom fields (warranty, barcode, etc.)
  meta Meta[]

  // Variable product variants & attributes
  variants   ProductVariant[]
  attributes ProductAttributeAssignment[]

  // Linked products
  upsells    Product[] @relation("ProductUpsells")
  upsellOf   Product[] @relation("ProductUpsells")
  crossSells Product[] @relation("ProductCrossSells")
  crossSellOf Product[] @relation("ProductCrossSells")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([brandId])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  mediaId   String
  media     Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  sortOrder Int     @default(0)

  @@unique([productId, mediaId])
  @@index([productId])
  @@map("product_images")
}

model ProductAttribute {
  id     String @id @default(uuid())
  name   String
  slug   String @unique

  values   ProductAttributeValue[]
  products ProductAttributeAssignment[]

  @@map("product_attributes")
}

model ProductAttributeValue {
  id          String           @id @default(uuid())
  value       String
  attributeId String
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  variants ProductVariantAttribute[]

  @@unique([attributeId, value])
  @@map("product_attribute_values")
}

model ProductAttributeAssignment {
  productId   String
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([productId, attributeId])
  @@map("product_attribute_assignments")
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku            String?       @unique
  regularPrice   Decimal?      @db.Decimal(12, 2)
  salePrice      Decimal?      @db.Decimal(12, 2)
  costPrice      Decimal?      @db.Decimal(12, 2)
  manageStock    Boolean       @default(false)
  quantity       Int           @default(0)
  stockStatus    StockStatus   @default(IN_STOCK)
  allowBackorder BackorderMode @default(NO)
  weight         Decimal?      @db.Decimal(10, 3)
  length         Decimal?      @db.Decimal(10, 2)
  width          Decimal?      @db.Decimal(10, 2)
  height         Decimal?      @db.Decimal(10, 2)

  attributes ProductVariantAttribute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("product_variants")
}

model ProductVariantAttribute {
  variantId String
  variant   ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  valueId   String
  value     ProductAttributeValue @relation(fields: [valueId], references: [id], onDelete: Cascade)

  @@id([variantId, valueId])
  @@map("product_variant_attributes")
}